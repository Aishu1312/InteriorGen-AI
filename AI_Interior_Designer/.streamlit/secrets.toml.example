# Copy this file to ".streamlit/secrets.toml" (which is gitignored) for
# local development, or paste the same keys into your Streamlit Cloud
# app's "Secrets" settings panel when deploying.

GROQ_API_KEY = "your_groq_api_key_here"
GROQ_MODEL = "llama-3.3-70b-versatile"

IMAGE_PROVIDER = "demo"

HF_API_KEY = "your_huggingface_api_key_here"
HF_MODEL = "black-forest-labs/FLUX.1-schnell"

STABILITY_API_KEY = "your_stability_api_key_here"

REPLICATE_API_TOKEN = "your_replicate_api_token_here"
REPLICATE_MODEL_VERSION = "your_model_version_id_here"

FAL_API_KEY = "your_fal_api_key_here"
