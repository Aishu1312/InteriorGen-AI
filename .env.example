# ============================================================
# AI Interior Designer Pro — Environment Variables Template
# Copy this file to ".env" for local development, OR configure
# the same keys under Streamlit Cloud "Secrets" as TOML (see
# .streamlit/secrets.toml.example / README for details).
# NEVER commit real API keys to version control.
# ============================================================

# --- Groq (required: powers prompt generation + AI Design Assistant chatbot) ---
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Model used for chat + prompt engineering.
# Any currently supported Groq-hosted model works, e.g.:
#   llama-3.3-70b-versatile
#   moonshotai/kimi-k2-instruct
GROQ_MODEL=llama-3.3-70b-versatile

# --- Image Generation Provider ---
# Which backend to use for turning prompts into images.
# Supported values: "huggingface", "stability", "replicate", "fal", "demo"
# "demo" requires no key and renders a styled placeholder mockup so the
# app always runs end-to-end even before you plug in a real image API.
IMAGE_PROVIDER=demo

# Hugging Face Inference API (used when IMAGE_PROVIDER=huggingface)
HF_API_KEY=your_huggingface_api_key_here
HF_MODEL=black-forest-labs/FLUX.1-schnell

# Stability AI (used when IMAGE_PROVIDER=stability)
STABILITY_API_KEY=your_stability_api_key_here

# Replicate (used when IMAGE_PROVIDER=replicate)
REPLICATE_API_TOKEN=your_replicate_api_token_here
REPLICATE_MODEL_VERSION=your_model_version_id_here

# Fal.ai (used when IMAGE_PROVIDER=fal)
FAL_API_KEY=your_fal_api_key_here
